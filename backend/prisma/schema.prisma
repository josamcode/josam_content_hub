generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentItemStatus {
  idea
  scripted
  recorded
  edited
  ready
  scheduled
  published
  failed
  archived
}

enum ContentCategory {
  programming
  software_engineering
  business_systems
  ara_financial
  portfolio_client_acquisition
  course_content
  saas_product_journey
  personal_brand
}

enum Platform {
  youtube
  instagram
  facebook
  tiktok
}

enum PlatformAccountStatus {
  connected
  needs_reauth
  revoked
  error
}

enum PlatformPostStatus {
  draft
  ready
  scheduled
  published
  failed
  manual_pending
  manual_done
}

enum ScheduleStatus {
  scheduled
  processing
  published
  failed
  cancelled
  manual_pending
  manual_done
}

enum PublishMode {
  auto
  manual
  reminder
}

enum ReminderStatus {
  pending
  done
  cancelled
  missed
}

enum PublishAttemptStatus {
  success
  failed
  skipped
  manual_completed
  cancelled
}

enum NotificationSeverity {
  info
  success
  warning
  error
}

enum MediaAssetType {
  video
  thumbnail
  image
  attachment
}

enum MediaAssetStatus {
  active
  missing
  deleted
}

enum AiGenerationType {
  platform_metadata
}

enum AiGenerationStatus {
  success
  failed
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  passwordHash            String                   @map("password_hash")
  contentItems            ContentItem[]
  queueSlots              QueueSlot[]
  platformSettings        PlatformSetting[]
  platformAccounts        PlatformAccount[]
  notificationEvents      NotificationEvent[]
  contentCategoryDefaults ContentCategoryDefault[]
  aiBrandProfile          AiBrandProfile?
  aiGenerationAttempts    AiGenerationAttempt[]
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  @@map("users")
}

model ContentItem {
  id            String            @id @default(cuid())
  userId        String            @map("user_id")
  title         String
  category      ContentCategory
  status        ContentItemStatus @default(idea)
  hook          String?
  script        String?
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  user          User              @relation(fields: [userId], references: [id])
  platformPosts PlatformPost[]
  mediaAssets   MediaAsset[]

  @@map("content_items")
}

model PlatformPost {
  id              String             @id @default(cuid())
  contentItemId   String             @map("content_item_id")
  platform        Platform
  title           String?
  caption         String?
  description     String?
  hashtags        String[]           @default([])
  tags            String[]           @default([])
  status          PlatformPostStatus @default(draft)
  platformPostUrl String?            @map("platform_post_url")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  contentItem     ContentItem        @relation(fields: [contentItemId], references: [id])
  schedule        Schedule?
  publishAttempts PublishAttempt[]

  @@unique([contentItemId, platform])
  @@map("platform_posts")
}

model QueueSlot {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  platform  Platform
  dayOfWeek Int      @map("day_of_week")
  timeOfDay String   @map("time_of_day")
  timezone  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, platform, dayOfWeek, timeOfDay])
  @@index([userId])
  @@index([platform])
  @@index([isActive])
  @@map("queue_slots")
}

model Schedule {
  id             String         @id @default(cuid())
  platformPostId String         @unique @map("platform_post_id")
  scheduledAt    DateTime       @map("scheduled_at")
  timezone       String
  status         ScheduleStatus @default(scheduled)
  publishMode    PublishMode    @map("publish_mode")
  attemptCount   Int            @default(0) @map("attempt_count")
  lastAttemptAt  DateTime?      @map("last_attempt_at")
  nextAttemptAt  DateTime?      @map("next_attempt_at")
  lastError      String?        @map("last_error")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  platformPost   PlatformPost   @relation(fields: [platformPostId], references: [id])
  reminder       Reminder?
  publishAttempts PublishAttempt[]

  @@index([scheduledAt])
  @@index([status])
  @@index([publishMode])
  @@index([status, nextAttemptAt])
  @@map("schedules")
}

model Reminder {
  id          String         @id @default(cuid())
  scheduleId  String         @unique @map("schedule_id")
  title       String
  message     String
  remindAt    DateTime       @map("remind_at")
  status      ReminderStatus @default(pending)
  createdAt   DateTime       @default(now()) @map("created_at")
  completedAt DateTime?      @map("completed_at")
  schedule    Schedule       @relation(fields: [scheduleId], references: [id])

  @@index([remindAt])
  @@index([status])
  @@map("reminders")
}

model PublishAttempt {
  id              String               @id @default(cuid())
  platformPostId  String               @map("platform_post_id")
  scheduleId      String?              @map("schedule_id")
  platform        Platform
  status          PublishAttemptStatus
  publishMode     PublishMode          @map("publish_mode")
  errorMessage    String?              @map("error_message")
  responsePayload Json?                @map("response_payload")
  attemptedAt     DateTime             @default(now()) @map("attempted_at")
  platformPost    PlatformPost         @relation(fields: [platformPostId], references: [id])
  schedule        Schedule?            @relation(fields: [scheduleId], references: [id])

  @@index([platformPostId])
  @@index([scheduleId])
  @@index([platform])
  @@index([status])
  @@index([attemptedAt])
  @@map("publish_attempts")
}

model PlatformSetting {
  id                  String      @id @default(cuid())
  userId              String      @map("user_id")
  platform            Platform
  isEnabled           Boolean     @default(true) @map("is_enabled")
  defaultPublishMode  PublishMode @default(manual) @map("default_publish_mode")
  defaultHashtags     String[]    @default([]) @map("default_hashtags")
  defaultTags         String[]    @default([]) @map("default_tags")
  captionTemplate     String?     @map("caption_template")
  titleTemplate       String?     @map("title_template")
  descriptionTemplate String?     @map("description_template")
  notes               String?
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  user                User        @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
  @@index([isEnabled])
  @@map("platform_settings")
}

model PlatformAccount {
  id                    String                @id @default(cuid())
  userId                String                @map("user_id")
  platform              Platform
  accountId             String?               @map("account_id")
  accountName           String?               @map("account_name")
  accessTokenEncrypted  String?               @map("access_token_encrypted")
  refreshTokenEncrypted String?               @map("refresh_token_encrypted")
  tokenExpiresAt        DateTime?             @map("token_expires_at")
  scopes                String[]              @default([])
  status                PlatformAccountStatus @default(connected)
  lastError             String?               @map("last_error")
  connectedAt           DateTime              @default(now()) @map("connected_at")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  user                  User                  @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
  @@index([status])
  @@map("platform_accounts")
}

model NotificationEvent {
  id          String               @id @default(uuid())
  userId      String               @map("user_id")
  type        String
  title       String
  message     String?
  severity    NotificationSeverity @default(info)
  entityType  String?              @map("entity_type")
  entityId    String?              @map("entity_id")
  payload     Json?
  isRead      Boolean              @default(false) @map("is_read")
  emailStatus String?              @map("email_status")
  sentAt      DateTime?            @map("sent_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  user        User                 @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([severity])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead, createdAt])
  @@map("notification_events")
}

model ContentCategoryDefault {
  id                  String          @id @default(cuid())
  userId              String          @map("user_id")
  category            ContentCategory
  defaultGoal         String?         @map("default_goal")
  defaultHookStyle    String?         @map("default_hook_style")
  defaultCaptionStyle String?         @map("default_caption_style")
  defaultHashtags     String[]        @default([]) @map("default_hashtags")
  defaultPlatforms    Platform[]      @default([]) @map("default_platforms")
  notes               String?
  isActive            Boolean         @default(true) @map("is_active")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  user                User            @relation(fields: [userId], references: [id])

  @@unique([userId, category])
  @@index([userId])
  @@index([category])
  @@index([isActive])
  @@map("content_category_defaults")
}

model AiBrandProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  audience             String?  @db.Text
  tone                 String?  @db.Text
  language             String?  @db.VarChar(80)
  contentGoal          String?  @db.Text @map("content_goal")
  ctaStyle             String?  @db.Text @map("cta_style")
  forbiddenWords       String[] @default([]) @map("forbidden_words")
  hashtagBank          String[] @default([]) @map("hashtag_bank")
  servicesToPromote    String[] @default([]) @map("services_to_promote")
  courseTopics         String[] @default([]) @map("course_topics")
  platformInstructions Json?    @map("platform_instructions")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id])

  @@map("ai_brand_profiles")
}

model AiGenerationAttempt {
  id           String              @id @default(cuid())
  userId       String              @map("user_id")
  type         AiGenerationType
  input        Json
  output       Json?
  status       AiGenerationStatus
  errorMessage String?             @map("error_message")
  provider     String
  model        String?
  createdAt    DateTime            @default(now()) @map("created_at")
  user         User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("ai_generation_attempts")
}

model MediaAsset {
  id                String           @id @default(cuid())
  contentItemId     String           @map("content_item_id")
  type              MediaAssetType
  status            MediaAssetStatus @default(active)
  fileUrl           String           @map("file_url")
  storageKey        String           @map("storage_key")
  fileName          String           @map("file_name")
  mimeType          String           @map("mime_type")
  fileSizeBytes     Int              @map("file_size_bytes")
  durationSeconds   Int?             @map("duration_seconds")
  width             Int?
  height            Int?
  aspectRatio       String?          @map("aspect_ratio")
  deletedAt         DateTime?        @map("deleted_at")
  missingDetectedAt DateTime?        @map("missing_detected_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  contentItem       ContentItem      @relation(fields: [contentItemId], references: [id])

  @@index([contentItemId])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
  @@map("media_assets")
}
