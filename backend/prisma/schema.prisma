generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentItemStatus {
  idea
  scripted
  recorded
  edited
  ready
  scheduled
  published
  failed
  archived
}

enum ContentCategory {
  programming
  software_engineering
  business_systems
  ara_financial
  portfolio_client_acquisition
  course_content
  saas_product_journey
  personal_brand
}

enum Platform {
  youtube
  instagram
  facebook
  tiktok
}

enum PlatformPostStatus {
  draft
  ready
  scheduled
  published
  failed
  manual_pending
  manual_done
}

enum ScheduleStatus {
  scheduled
  processing
  published
  failed
  cancelled
  manual_pending
  manual_done
}

enum PublishMode {
  auto
  manual
  reminder
}

enum ReminderStatus {
  pending
  done
  cancelled
  missed
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  contentItems ContentItem[]
  queueSlots   QueueSlot[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

model ContentItem {
  id            String            @id @default(cuid())
  userId        String            @map("user_id")
  title         String
  category      ContentCategory
  status        ContentItemStatus @default(idea)
  hook          String?
  script        String?
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  user          User              @relation(fields: [userId], references: [id])
  platformPosts PlatformPost[]

  @@map("content_items")
}

model PlatformPost {
  id              String             @id @default(cuid())
  contentItemId   String             @map("content_item_id")
  platform        Platform
  title           String?
  caption         String?
  description     String?
  hashtags        String[]           @default([])
  tags            String[]           @default([])
  status          PlatformPostStatus @default(draft)
  platformPostUrl String?            @map("platform_post_url")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  contentItem     ContentItem        @relation(fields: [contentItemId], references: [id])
  schedule        Schedule?

  @@unique([contentItemId, platform])
  @@map("platform_posts")
}

model QueueSlot {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  platform  Platform
  dayOfWeek Int      @map("day_of_week")
  timeOfDay String   @map("time_of_day")
  timezone  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, platform, dayOfWeek, timeOfDay])
  @@index([userId])
  @@index([platform])
  @@index([isActive])
  @@map("queue_slots")
}

model Schedule {
  id             String         @id @default(cuid())
  platformPostId String         @unique @map("platform_post_id")
  scheduledAt    DateTime       @map("scheduled_at")
  timezone       String
  status         ScheduleStatus @default(scheduled)
  publishMode    PublishMode    @map("publish_mode")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  platformPost   PlatformPost   @relation(fields: [platformPostId], references: [id])
  reminder       Reminder?

  @@index([scheduledAt])
  @@index([status])
  @@index([publishMode])
  @@map("schedules")
}

model Reminder {
  id          String         @id @default(cuid())
  scheduleId  String         @unique @map("schedule_id")
  title       String
  message     String
  remindAt    DateTime       @map("remind_at")
  status      ReminderStatus @default(pending)
  createdAt   DateTime       @default(now()) @map("created_at")
  completedAt DateTime?      @map("completed_at")
  schedule    Schedule       @relation(fields: [scheduleId], references: [id])

  @@index([remindAt])
  @@index([status])
  @@map("reminders")
}
