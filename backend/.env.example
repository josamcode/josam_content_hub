NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/josam_content_hub
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
SEED_USER_NAME=JoSam
SEED_USER_EMAIL=josam@example.com
SEED_USER_PASSWORD=change_this_password
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:5000/uploads
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Staging examples:
# STAGING FRONTEND_URL=https://content.example.com
# STAGING ALLOWED_ORIGINS=https://content.example.com
# STAGING PUBLIC_UPLOAD_BASE_URL=https://api-content.example.com/uploads
# STAGING UPLOAD_DIR=/app/uploads or mounted persistent path

# Optional manual PostgreSQL backup helper:
# BACKUP_DATABASE_URL=postgresql://postgres:password@localhost:5432/josam_content_hub
# BACKUP_DIR=./backups/postgres
# BACKUP_ALLOW_REMOTE=false

# Optional manual uploads backup helper:
# BACKUP_UPLOADS_DIR=uploads
# BACKUP_DIR=./backups/uploads
# BACKUP_TAR_BIN=tar
