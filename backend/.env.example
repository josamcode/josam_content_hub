NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/josam_content_hub
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
# Required before storing OAuth access/refresh tokens. Use 32 random bytes as 64 hex chars.
# Example generation: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENCRYPTION_KEY=
# YouTube OAuth connection settings. Required before using /integrations/youtube/connect.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/integrations/youtube/callback
# YOUTUBE_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/settings/platforms?youtube=connected
# YOUTUBE_OAUTH_ERROR_REDIRECT_URL=http://localhost:5173/settings/platforms?youtube=error
YOUTUBE_UPLOAD_PRIVACY_STATUS=private
# YOUTUBE_DEFAULT_CATEGORY_ID=
# In-process scheduled YouTube auto-upload worker:
YOUTUBE_AUTO_UPLOAD_WORKER_ENABLED=false
YOUTUBE_AUTO_UPLOAD_WORKER_INTERVAL_MS=60000
YOUTUBE_AUTO_UPLOAD_WORKER_BATCH_SIZE=1
YOUTUBE_AUTO_UPLOAD_WORKER_MAX_ATTEMPTS=3
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
SEED_USER_NAME=JoSam
SEED_USER_EMAIL=josam@example.com
SEED_USER_PASSWORD=change_this_password
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:5000/uploads
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SMTP email notifications. Disabled by default; do not commit real credentials.
EMAIL_ENABLED=false
EMAIL_FROM="JoSam Content Hub <notifications@example.com>"
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Staging examples:
# STAGING FRONTEND_URL=https://content.example.com
# STAGING ALLOWED_ORIGINS=https://content.example.com
# STAGING PUBLIC_UPLOAD_BASE_URL=https://api-content.example.com/uploads
# STAGING UPLOAD_DIR=/app/uploads or mounted persistent path

# Optional manual PostgreSQL backup helper:
# BACKUP_DATABASE_URL=postgresql://postgres:password@localhost:5432/josam_content_hub
# BACKUP_DIR=./backups/postgres
# BACKUP_ALLOW_REMOTE=false

# Optional manual uploads backup helper:
# BACKUP_UPLOADS_DIR=uploads
# BACKUP_DIR=./backups/uploads
# BACKUP_TAR_BIN=tar
